BINANCE_API_KEY=
BINANCE_SECRET=
# Use host.docker.internal when running in Docker, or localhost for bare-metal
LLAMA_BASE_URL=http://host.docker.internal:11434/v1
LLAMA_MODEL=llama3

# Per-module LLM defaults (optional — falls back to LLAMA_BASE_URL / LLAMA_MODEL).
# These are the *fallback* values; each module's endpoint, model AND max-tokens can
# also be overridden at runtime from the Settings → LLM Models page (a blank field —
# or max tokens 0 — there uses the value set here).
EXTRACTOR_BASE_URL=
EXTRACTOR_MODEL=
EXTRACTOR_MAX_TOKENS=8192
EXTRACTOR_MAX_ARTICLE_CHARS=1200
EXTRACTOR_MAX_CHALLENGE_CHARS=600
ANALYST_BASE_URL=
ANALYST_MODEL=
ANALYST_MAX_TOKENS=28000
DISCOVERER_BASE_URL=
DISCOVERER_MODEL=
DISCOVERER_MAX_TOKENS=512
DISCOVERER_EXTRACTOR_BASE_URL=
DISCOVERER_EXTRACTOR_MODEL=
DISCOVERER_EXTRACTOR_MAX_TOKENS=8192
# Agent Monitor — the agentic position monitor. A tool-calling loop per open position, so
# point it at a tool-calling-capable model. Falls back to LLAMA_BASE_URL / LLAMA_MODEL.
MONITOR_BASE_URL=
MONITOR_MODEL=
MONITOR_MAX_TOKENS=4096

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
APPROVAL_TIMEOUT_MINUTES=5
PORT=3000

# --- Authentication gateway -------------------------------------------------
# Protects the API + WebSocket behind a login. It turns ON automatically once a
# password is configured (AUTH_PASSWORD_HASH or AUTH_PASSWORD); when neither is
# set the trader is OPEN to anyone who can reach the port (a warning is logged).
# Generate a hash + secret without putting the plaintext in .env:
#   cd backend && npm run auth:hash -- 'your-strong-password'
# IMPORTANT: do NOT wrap these values in quotes. The hash is ':'-delimited (not
# '$') so it is safe to paste verbatim — a '$' here would be eaten by Docker
# Compose's variable interpolation and corrupt the value.
AUTH_USERNAME=admin
# Preferred: a precomputed scrypt hash (plaintext never stored in .env).
AUTH_PASSWORD_HASH=
# Convenience alternative — plaintext, hashed at boot. Prefer AUTH_PASSWORD_HASH.
AUTH_PASSWORD=
# HMAC signing secret for bearer tokens (>=16 chars). If unset, an ephemeral one
# is generated each boot and all sessions reset on restart. Set it for stability.
AUTH_SECRET=
# Session lifetime in minutes (default 720 = 12h).
AUTH_TOKEN_TTL_MINUTES=720
# Explicit override: 'true' forces auth on (errors if no password), 'false' off.
# AUTH_ENABLED=