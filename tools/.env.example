# tools/ configuration — copy to tools/.env and fill in.
#
# db.mjs talks to the backend's read-only debug API (no direct DB access).

# Backend base URL (where the API server listens).
BOT_API_URL=http://localhost:3000

# Debug API key. Create one in the app: Settings → API Keys → Create key.
# The full key is shown only once on creation — paste it here.
BOT_API_KEY=
